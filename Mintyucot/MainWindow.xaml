<Window x:Class="Mintyucot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Mintyucot"
        mc:Ignorable="d"
        Title="MainWindow" Height="196" Width="249"
        ResizeMode="CanResize">
    <Grid>
        <Menu Height="18" VerticalAlignment="Top">
            <MenuItem x:Name="FileMenu"
                    Header="ファイル(_F)">
                <MenuItem x:Name="ExitMenuItem" Header="終了(_X)" Click="ExitMenuItemOnClick"/>
            </MenuItem>
        </Menu>
        <StackPanel Margin="10,23,10,10">
            <Button x:Name="AddImageMascotButton"
                Content="Image"
                Height="24" Click="AddImageMascotButtonOnClick"/>
        </StackPanel>

    </Grid>
</Window>
