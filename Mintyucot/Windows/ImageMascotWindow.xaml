<Window x:Class="Mintyucot.Windows.ImageMascotWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Mintyucot.Windows"
        mc:Ignorable="d"
        Title="ImageMascotWindow" Height="373" Width="380" ShowInTaskbar="False" WindowStyle="None"
        Background="Transparent"
        AllowsTransparency="True" Activated="ImageMascotWindowOnActivated" Deactivated="ImageMascotWindowOnDeactivated">
    <Grid>
        <TextBlock x:Name="TopResizeBlock"
            TextWrapping="Wrap" Text="" VerticalAlignment="Top" Background="#FF7100FF" Height="9"/>
        <TextBlock x:Name="LeftResizeBlock"
            HorizontalAlignment="Left" Margin="0,9,0,0" TextWrapping="Wrap" Text="" Background="#FF7100FF" Width="9"/>
        <TextBlock x:Name="BottomResizeBlock"
            Margin="9,0,0,0" TextWrapping="Wrap" Text="" Background="#FF7100FF" VerticalAlignment="Bottom" Height="9"/>
        <TextBlock x:Name="RightResizeBlock"
            HorizontalAlignment="Right" Margin="0,9,0,9" TextWrapping="Wrap" Text="" Background="#FF7100FF" Width="9"/>
        <Image 
            x:Name="MascotMainImage"
            Margin="9,9,9,9" MouseLeftButtonDown="MascotMainImageOnMouseLeftButtonDown"/>

    </Grid>
</Window>
